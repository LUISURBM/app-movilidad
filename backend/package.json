{
  "name": "@fleetspecial/backend",
  "version": "0.1.0",
  "description": "Backend NestJS (monolito modular) de FleetSpecial. Módulo inicial: Compliance & Documents (CORE).",
  "license": "LicenseRef-Proprietary",
  "type": "module",
  "scripts": {
    "start:dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"**/*.integration.spec.ts\" --exclude \"**/*.e2e.spec.ts\"",
    "test:integration": "vitest run \"**/*.integration.spec.ts\"",
    "test:e2e": "vitest run \"**/*.e2e.spec.ts\"",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
